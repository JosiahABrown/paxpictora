---
import { getImage } from 'astro:assets';
import portraitRaw from '../assets/images/pfp.jpg';
const portrait = await getImage({ src: portraitRaw });
---

<section class="about" id="about">
  <div class="about-grid">
    <div
      class="about-portrait reveal"
      style={`background-image: url('${portrait.src}')`}
      aria-label="Portrait of the photographer"
    >
      <span class="about-caption">Self-portrait · Oregon Coast</span>
    </div>
    <div class="about-copy reveal">
      <div class="section-label">On the Photographer</div>
      <h2>A patient eye for <em>quiet, lasting</em> light.</h2>
      <p class="lede">My name is <em>Josiah</em>. When I was 11 years old, I took a photo of a sunset on the Dead Sea in Israel. I instantly fell in love with photography. 
        Since then my photography as been showcased on stamps, and in international art galleries. Recently, I have worked various events such as 
        Texas Tech Graduation, OU Football, Proms, children's sporting events, and parties for the Oklahoma Historical Society.
        If you have any questions about my services or just want to chat, feel free to send me an email below!
        <br><em>Pax Pictora</em> means roughly means <b>"Peace Pictures"</b> in latin.
      </p>
      <div class="about-signature">
        <span class="sig">— Josiah Brown</span>
        <span class="role">Founder · Photographer</span>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--ink);
    padding: 160px 80px;
    position: relative;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 110px;
    align-items: center;
    max-width: 1360px;
    margin: 0 auto;
  }

  .about-portrait {
    aspect-ratio: 4 / 5;
    background-position: center 25%;
    background-size: cover;
    background-repeat: no-repeat;
    position: relative;
    filter: saturate(0.78) contrast(1.02);
  }

  .about-portrait::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(21, 17, 13, 0.05), rgba(21, 17, 13, 0.25));
    mix-blend-mode: multiply;
  }

  .about-caption {
    position: absolute;
    left: 0;
    bottom: -28px;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--taupe);
  }

  .section-label {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 36px;
  }

  .section-label::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--accent);
  }

  .about-copy h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 4.4vw, 68px);
    line-height: 1.05;
    letter-spacing: -0.012em;
    margin: 0 0 36px;
    color: var(--cream);
    text-wrap: balance;
  }

  .about-copy h2 em {
    font-style: italic;
    font-weight: 400;
    color: var(--cream-dim);
  }

  .about-copy p {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 19px;
    line-height: 1.62;
    color: var(--cream-dim);
    margin: 0 0 22px;
    max-width: 56ch;
    text-wrap: pretty;
  }

  .about-copy p.lede::first-letter {
    font-family: var(--serif);
    font-weight: 500;
    font-style: italic;
    font-size: 4.4em;
    float: left;
    line-height: 0.86;
    margin: 6px 14px 0 0;
    color: var(--accent);
  }

  .about-signature {
    margin-top: 48px;
    display: flex;
    align-items: baseline;
    gap: 22px;
  }

  .about-signature .sig {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 30px;
    color: var(--cream);
    letter-spacing: -0.005em;
  }

  .about-signature .role {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--taupe);
  }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 1000ms cubic-bezier(0.2, 0.6, 0.2, 1), transform 1000ms cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .reveal.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 960px) {
    .about { padding: 110px 28px; }
    .about-grid { grid-template-columns: 1fr; gap: 60px; }
  }
</style>
