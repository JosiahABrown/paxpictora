---
<section class="py-section-gap px-margin-edge bg-background">
    <div class="max-w-3xl mx-auto">
        <h2 class="font-playfair text-display-lg text-primary mb-12 text-center">Initiate Contact</h2>
        <form class="space-y-8 bg-surface-container-lowest p-12 rounded-xl soft-shadow">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label class="font-manrope font-semibold text-on-surface block text-xs tracking-widest uppercase">Identification / Name</label>
                    <input class="w-full bg-surface-container-low border-none rounded-xl p-4 font-manrope text-on-surface focus:ring-1 focus:ring-primary focus:outline-none" placeholder="Enter Name" type="text" required/>
                </div>
                <div class="space-y-2">
                    <label class="font-manrope font-semibold text-on-surface block text-xs tracking-widest uppercase">Signal / Email</label>
                    <input class="w-full bg-surface-container-low border-none rounded-xl p-4 font-manrope text-on-surface focus:ring-1 focus:ring-primary focus:outline-none" placeholder="Enter Email" type="email" required/>
                </div>
            </div>
            <div class="space-y-2">
                <label class="font-manrope font-semibold text-on-surface block text-xs tracking-widest uppercase">The Subject / What do you want photos of?</label>
                <textarea class="w-full bg-surface-container-low border-none rounded-xl p-4 font-manrope text-on-surface focus:ring-1 focus:ring-primary focus:outline-none" placeholder="Describe the vision" rows="4" required></textarea>
            </div>
            <button class="bg-primary text-on-primary rounded-xl px-8 py-4 font-manrope font-semibold w-full hover:bg-inverse-surface transition-colors" type="submit">
                Submit Inquiry
            </button>
        </form>
    </div>
</section>

<style>
    .font-playfair { font-family: var(--font-family-serif); }
    .font-manrope { font-family: var(--font-family-body); }
    .text-display-lg { font-size: 48px; line-height: 1.1; letter-spacing: -0.02em; }
    .soft-shadow { box-shadow: 0 4px 24px rgba(0,0,0,0.04); }
</style>