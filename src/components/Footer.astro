---
const currentYear = new Date().getFullYear();
---
<footer class="w-full py-12 px-margin-edge flex justify-between items-center bg-surface-container-low text-on-surface border-t border-surface-variant mt-section-gap">
    <div class="font-manrope font-semibold tracking-widest uppercase text-xs">
        Pax Pictora © {currentYear} All Rights Reserved
    </div>
    <div class="flex gap-8 font-manrope font-semibold tracking-widest uppercase text-xs">
        <a class="hover:text-secondary transition-colors" href="#">Instagram</a>
        <a class="hover:text-secondary transition-colors" href="#">Behance</a>
        <a class="hover:text-secondary transition-colors" href="#">LinkedIn</a>
    </div>
</footer>

<style>
    /* Local mapping for the body font */
    .font-manrope { font-family: var(--font-family-body); }
</style>