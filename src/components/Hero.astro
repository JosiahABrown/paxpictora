---
import { Image } from 'astro:assets';
import placeholder from '../assets/images/placeholder.jpg';
---
<header class="relative w-full min-h-[921px] flex items-end px-margin-edge pb-section-gap pt-[120px]">
    <div class="absolute inset-0 z-0 m-gutter rounded-xl overflow-hidden">
        <Image src={placeholder} alt="Hero background" class="w-full h-full object-cover opacity-80" />
        <div class="absolute inset-0 bg-background/20 mix-blend-overlay"></div>
    </div>
    <div class="relative z-10 max-w-4xl bg-surface/90 backdrop-blur-md rounded-xl p-12 soft-shadow ml-gutter mb-gutter">
        <h1 class="font-playfair text-display-lg text-primary">
            Pax Pictora: <br/><span class="text-secondary">Framing</span> the Unspoken
        </h1>
    </div>
</header>

<style>
    .font-playfair { font-family: var(--font-family-serif); }
    .text-display-lg { font-size: 48px; line-height: 1.1; letter-spacing: -0.02em; }
    .soft-shadow { box-shadow: 0 4px 24px rgba(0,0,0,0.04); }
</style>