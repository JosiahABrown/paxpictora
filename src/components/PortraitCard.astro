---
import { Image } from 'astro:assets';

interface Props {
    role: string;
    name: string;
    tag: string;
    image: ImageMetadata;
}

const { role, name, tag, image } = Astro.props;
---
<article class="break-inside-avoid mb-6 block w-full max-w-full">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm relative group w-full">
        <Image src={image} alt={name} class="w-full max-w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105 block" />
        </div>
</article>