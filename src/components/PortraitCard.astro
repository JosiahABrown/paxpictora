---
import { Image } from 'astro:assets';

interface Props {
    role: string;
    name: string;
    tag: string;
    image: ImageMetadata;
}

const { role, name, tag, image } = Astro.props;
---
<article class="break-inside-avoid mb-6 block">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm relative group">
        <Image src={image} alt={name} class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105" />
        <div class="p-6 bg-surface-container-lowest flex justify-between items-start relative z-10">
            <div>
                <p class="font-sans text-xs font-semibold tracking-widest uppercase text-secondary">{role}</p>
                <p class="font-serif text-xl text-primary mt-2">{name}</p>
            </div>
            <span class="bg-surface-container text-on-surface px-3 py-1 font-sans text-[10px] font-semibold tracking-widest rounded-full uppercase">{tag}</span>
        </div>
    </div>
</article>