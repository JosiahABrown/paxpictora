---
// Sidebar.astro
---
<header class="md:hidden fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 py-6 bg-surface border-b border-outline-variant">
    <div class="text-3xl font-serif text-primary uppercase">Pax Pictora</div>
    <button class="text-primary border border-outline px-4 py-2 font-sans text-xs font-semibold tracking-widest uppercase rounded-full hover:bg-surface-container transition-colors">Menu</button>
</header>

<nav class="hidden md:flex fixed left-0 top-0 h-full flex-col pt-24 w-72 bg-surface border-r border-outline-variant z-40">
    <div class="px-8 mb-12">
        <h1 class="text-primary font-serif text-4xl mb-2">PAX PICTORA</h1>
        <p class="font-sans text-xs font-semibold text-on-surface-variant uppercase tracking-widest">Archive</p>
    </div>
    
    <div class="flex flex-col w-full font-sans text-xs font-semibold uppercase tracking-widest px-4 space-y-2">
        <a class="text-on-surface p-4 rounded-xl flex items-center gap-4 hover:bg-surface-container transition-colors" href="#">
            <span class="material-symbols-outlined">domain</span> Real Estate
        </a>
        <a class="bg-secondary-container text-on-secondary-container p-4 rounded-xl flex items-center gap-4" href="#">
            <span class="material-symbols-outlined">badge</span> Business Portraits
        </a>
        <a class="text-on-surface p-4 rounded-xl flex items-center gap-4 hover:bg-surface-container transition-colors" href="#">
            <span class="material-symbols-outlined">groups</span> Family Portraits
        </a>
        <a class="text-on-surface p-4 rounded-xl flex items-center gap-4 hover:bg-surface-container transition-colors" href="#">
            <span class="material-symbols-outlined">landscape</span> Nature
        </a>
    </div>
    
    <div class="mt-auto p-8 border-t border-outline-variant">
        <a class="block w-full text-center bg-primary text-on-primary font-sans text-xs font-semibold uppercase tracking-widest py-4 rounded-xl hover:bg-inverse-surface transition-colors" href="#contact">
            Book Session
        </a>
    </div>
</nav>