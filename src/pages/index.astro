---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

// Use placeholders for all images on homepage
import placeholder from '../assets/images/placeholder.jpg';

// Service Data
const services = [
  { title: "Real Estate", description: "Structural. Dominant. Uncompromising.", icon: "domain", image: placeholder },
  { title: "Portraits", description: "Raw. Human. Architectural.", icon: "groups", image: placeholder },
  { title: "Nature", description: "Savage. Immutable. Permanent.", icon: "landscape", image: placeholder },
];

// Testimonial Data
const testimonials = [
  { quote: "Pax didn't just take pictures; they built monuments out of light and shadow.", name: "Director V. Kane", type: "Commercial Editorial" },
  { quote: "Uncompromising vision. The real estate shots felt like brutalist sculptures.", name: "M. Thorne", type: "Thorne Architecture" },
];
---

<Layout title="Pax Pictora | Framing The Unspoken">
    <Navbar />
    
    <main>
        <Hero />

        <section class="py-section-gap px-margin-edge bg-background">
            <div class="max-w-container-max mx-auto">
                <h2 class="font-playfair text-display-lg text-primary mb-16">Services / <span class="text-secondary">Archive</span></h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
                    {services.map((service) => (
                        <ServiceCard {...service} />
                    ))}
                </div>
            </div>
        </section>

        <section class="py-section-gap px-margin-edge bg-surface-container-low">
            <div class="max-w-container-max mx-auto flex flex-col md:flex-row gap-16 items-start">
                <div class="md:w-1/3">
                    <h2 class="font-playfair text-display-lg text-primary mb-8">The<br/>Echo</h2>
                    <p class="font-manrope text-on-surface-variant">Voices of those who stood before the lens.</p>
                </div>
                <div class="md:w-2/3 flex overflow-x-auto gap-8 pb-8 snap-x">
                    {testimonials.map((testimonial) => (
                        <TestimonialCard {...testimonial} />
                    ))}
                </div>
            </div>
        </section>

        <ContactForm />
    </main>
    
    <Footer />
</Layout>

<style>
    .font-playfair { font-family: var(--font-family-serif); }
    .font-manrope { font-family: var(--font-family-body); }
    .text-display-lg { font-size: 48px; line-height: 1.1; letter-spacing: -0.02em; }
</style>