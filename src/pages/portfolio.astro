---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const CAT_LABEL: Record<string, string> = {
  'real-estate': 'Real Estate',
  'portraits': 'Portraits',
  'events': 'Events',
  'nature': 'Nature',
};
const CAT_ORDER = ['real-estate', 'portraits', 'events', 'nature'];

// Editorial titles, keyed by the image's own file name (kept as the identifier).
const TITLES: Record<string, string> = {
  // Real Estate
  'Front3': 'The approach',
  'LivingRoom1': 'Living room, in light',
  'Kitchen1': 'Kitchen, morning',
  'Kitchen3': 'Kitchen, at the stove',
  'Master1': 'Primary suite',
  'Bedroom2-1': 'A second bedroom',
  'MasterBath2': 'Primary bath',
  // Portraits
  'studio': 'Studio sitting',
  'outdoor-portrait': 'Portrait, out of doors',
  'outdoor-family': 'A family, gathered',
  'allstate-1': 'On assignment, I',
  'allstate-2': 'On assignment, II',
  // Events
  'BNI-1': 'Among colleagues, I',
  'BNI-2': 'Among colleagues, II',
  'Paws-and-pumpkins-1': 'Paws & Pumpkins, I',
  'Paws-and-pumpkins-2': 'Paws & Pumpkins, II',
  'Paws-and-pumpkins-3': 'Paws & Pumpkins, III',
  // Nature
  'astro-sunset-point-bryce-canyon': 'Sunset Point, Bryce Canyon',
  'astro-utah-tree': 'Lone tree, under stars',
  'beach-sunset-reflection': 'Sunset, in reflection',
  'Tetons': 'The Tetons',
  'longhorn': 'Longhorn, at rest',
  'sleeping-bee': 'A sleeping bee',
  'Cucumber-beetle': 'Cucumber beetle',
};

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/portfolio/**/*.{jpg,jpeg,JPG,png,webp}',
  { eager: true },
);

// Cap rendered width to keep page weight down — the lightbox tops out at 1200px,
// so 1600px covers it (and gallery columns) on hi-DPI screens without upscaling.
const MAX_WIDTH = 1600;

const tiles = await Promise.all(
  Object.entries(modules).map(async ([path, mod]) => {
    const segments = path.split('/');
    const cat = segments[segments.length - 2];
    const file = segments[segments.length - 1].replace(/\.[^.]+$/, '');
    const optimized = await getImage({
      src: mod.default,
      width: Math.min(mod.default.width, MAX_WIDTH),
    });
    return {
      cat,
      file,
      title: TITLES[file] ?? file.replace(/[-_]/g, ' '),
      src: optimized.src,
      width: mod.default.width,
      height: mod.default.height,
    };
  }),
);

// Group by the tab order, then by file name within each category.
tiles.sort((a, b) => {
  const byCat = CAT_ORDER.indexOf(a.cat) - CAT_ORDER.indexOf(b.cat);
  return byCat !== 0 ? byCat : a.file.localeCompare(b.file);
});

const counts: Record<string, number> = Object.fromEntries(
  CAT_ORDER.map((c) => [c, tiles.filter((t) => t.cat === c).length]),
);
const pad = (n: number) => String(n).padStart(2, '0');
---

<Layout title="Pax Pictora — Portfolio">
  <Navigation currentPage="portfolio" frosted />

  <section class="page-intro">
    <div class="top">
      <h1>The <em>Portfolio.</em></h1>
      <div class="meta">
        <div><strong>2016 — 2026</strong></div>
        <div>A Decade of photos</div>
        <div>Edited &amp; archived</div>
      </div>
    </div>
    <div class="section-label">A selected archive</div>
    <p class="dek">A small, deliberate selection of recent work — residences, sittings, occasions, and the quieter studies in between. Photos may be revisited; nothing is final.</p>
  </section>

  <div class="tabs-wrap">
    <div class="tabs" role="tablist" aria-label="Categories">
      <div class="tab-row">
        <button class="tab is-active" data-cat="all" role="tab">All <span class="count">·{pad(tiles.length)}</span></button>
        {CAT_ORDER.map((c) => (
          <button class="tab" data-cat={c} role="tab">{CAT_LABEL[c]} <span class="count">·{pad(counts[c])}</span></button>
        ))}
      </div>
      <div class="tab-meta" id="tabMeta">Showing {tiles.length} photos</div>
    </div>
  </div>

  <main class="gallery" id="gallery"></main>

  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox-close" id="lbClose" aria-label="Close">
      Close <span class="x" aria-hidden="true"></span>
    </button>
    <button class="lightbox-nav prev" id="lbPrev" aria-label="Previous">
      <span class="line" aria-hidden="true"></span> Prev
    </button>
    <div class="lightbox-stage">
      <div class="lightbox-frame" id="lbFrame"></div>
      <div class="lightbox-caption" id="lbCaption">
        <span class="lb-plate"></span>
        <span class="lb-title"></span>
        <span class="lb-meta"></span>
      </div>
    </div>
    <button class="lightbox-nav next" id="lbNext" aria-label="Next">
      Next <span class="line" aria-hidden="true"></span>
    </button>
  </div>
</Layout>

<style>
  /* Page intro */
  .page-intro {
    padding: 180px 80px 60px;
    max-width: 1500px;
    margin: 0 auto;
  }

  .page-intro .top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 60px;
    margin-bottom: 80px;
  }

  .page-intro h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(72px, 11vw, 168px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--cream);
  }

  .page-intro h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--cream-dim);
  }

  .page-intro .meta {
    text-align: right;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--taupe);
    line-height: 1.9;
  }

  .page-intro .meta strong {
    color: var(--cream);
    font-weight: 400;
  }

  .section-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .section-label::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--accent);
  }

  .dek {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    line-height: 1.5;
    color: var(--cream-dim);
    max-width: 52ch;
    margin: 0;
  }

  /* Tabs */
  .tabs-wrap {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(21, 17, 13, 0.92);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
  }

  .tabs {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .tabs .tab-row {
    display: flex;
    gap: 6px;
  }

  .tab {
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--taupe);
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    padding: 28px 22px;
    cursor: pointer;
    position: relative;
    transition: color 320ms ease;
  }

  .tab .count {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    margin-left: 8px;
    color: var(--taupe-dim);
    vertical-align: super;
    transition: color 320ms ease;
  }

  .tab:hover { color: var(--cream-dim); }
  .tab.is-active { color: var(--cream); }
  .tab.is-active .count { color: var(--accent); }

  .tab::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: -1px;
    height: 1px;
    background: var(--cream);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 360ms cubic-bezier(0.6, 0.05, 0.2, 1);
  }

  .tab.is-active::after { transform: scaleX(1); }

  .tab-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--taupe);
  }

  /* Masonry gallery */
  .gallery {
    max-width: 1500px;
    margin: 0 auto;
    padding: 60px 80px 120px;
    column-count: 3;
    column-gap: 28px;
  }

  /* Tiles */
  :global(.tile) {
    break-inside: avoid;
    margin-bottom: 28px;
    position: relative;
    display: block;
    cursor: zoom-in;
    overflow: hidden;
    background: var(--ink-2);
    transition: opacity 500ms ease, filter 500ms ease;
    text-decoration: none;
    color: inherit;
  }

  :global(.tile.is-hidden) { display: none; }

  :global(.tile-frame) {
    width: 100%;
    display: block;
    position: relative;
  }

  :global(.tile img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 1200ms cubic-bezier(0.2, 0.6, 0.2, 1), filter 600ms ease;
  }

  :global(.tile:hover img) {
    transform: scale(1.03);
  }

  :global(.tile-caption) {
    padding: 14px 2px 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  :global(.tile-caption .ttl) {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--cream-dim);
    line-height: 1.25;
  }

  :global(.tile-caption .num) {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--taupe-dim);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .gallery:hover :global(.tile:not(:hover)) {
    filter: brightness(0.7) saturate(0.85);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(15, 12, 9, 0.78);
    backdrop-filter: blur(22px) saturate(120%);
    -webkit-backdrop-filter: blur(22px) saturate(120%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 80px 120px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 480ms ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-stage {
    position: relative;
    max-width: min(1200px, 100%);
    max-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .lightbox-frame {
    max-width: 100%;
    max-height: calc(100vh - 240px);
    transform: scale(0.97);
    transition: transform 600ms cubic-bezier(0.2, 0.6, 0.2, 1);
    position: relative;
  }

  .lightbox.is-open .lightbox-frame { transform: scale(1); }

  .lightbox-frame :global(> *) {
    max-width: 100%;
    max-height: calc(100vh - 240px);
    display: block;
  }

  .lightbox-caption {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 40px;
    align-items: baseline;
    width: 100%;
    color: var(--cream);
    border-top: 1px solid var(--rule);
    padding-top: 22px;
  }

  .lightbox-caption .lb-plate {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .lightbox-caption .lb-title {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    color: var(--cream);
    letter-spacing: 0.005em;
  }

  .lightbox-caption .lb-meta {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--taupe);
    text-align: right;
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 32px;
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--cream-dim);
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 10px;
    transition: color 220ms ease;
  }

  .lightbox-close:hover { color: var(--cream); }

  .lightbox-close .x {
    width: 18px;
    height: 18px;
    position: relative;
  }

  .lightbox-close .x::before,
  .lightbox-close .x::after {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 50%;
    height: 1px;
    background: currentColor;
  }

  .lightbox-close .x::before { transform: rotate(45deg); }
  .lightbox-close .x::after  { transform: rotate(-45deg); }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--cream-dim);
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 18px 22px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    transition: color 220ms ease, gap 220ms ease;
  }

  .lightbox-nav:hover { color: var(--cream); gap: 22px; }
  .lightbox-nav.prev { left: 24px; }
  .lightbox-nav.next { right: 24px; }

  .lightbox-nav .line {
    width: 36px;
    height: 1px;
    background: currentColor;
    position: relative;
  }

  .lightbox-nav .line::after {
    content: "";
    position: absolute;
    width: 8px;
    height: 1px;
    background: currentColor;
    top: -3px;
  }

  .lightbox-nav.next .line::after { right: 0; transform: rotate(35deg); transform-origin: right center; }
  .lightbox-nav.prev .line::after { left: 0; transform: rotate(-35deg); transform-origin: left center; }

  @media (max-width: 960px) {
    .page-intro { padding: 130px 28px 40px; }
    .page-intro .top { flex-direction: column; align-items: flex-start; gap: 28px; }
    .page-intro .meta { text-align: left; }
    .tabs { padding: 0 16px; overflow-x: auto; }
    .tab { padding: 22px 14px; }
    .gallery { column-count: 2; padding: 40px 28px 60px; }

    /* Not enough side room — drop the nav below the image instead of over it. */
    .lightbox {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "stage stage"
        "prev  next";
      align-content: center;
      gap: 18px;
      padding: 64px 16px 28px;
    }
    .lightbox-stage { grid-area: stage; justify-self: center; }
    .lightbox-frame,
    .lightbox-frame :global(> *) { max-height: calc(100vh - 320px); }
    .lightbox-nav {
      position: static;
      transform: none;
      padding: 14px 8px;
    }
    .lightbox-nav.prev { grid-area: prev; justify-self: start; }
    .lightbox-nav.next { grid-area: next; justify-self: end; }
    .lightbox-nav:hover { gap: 14px; }
  }

  @media (max-width: 640px) {
    .gallery { column-count: 1; }
    .lightbox-caption {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .lightbox-caption .lb-meta { text-align: left; }
  }
</style>

<script define:vars={{ TILES: tiles, CAT_LABEL }}>
  const pad = (n) => String(n).padStart(2, '0');

  const gallery = document.getElementById('gallery');

  TILES.forEach((t, i) => {
    const a = document.createElement('a');
    a.href = '#';
    a.className = 'tile';
    a.dataset.cat = t.cat;
    a.dataset.idx = String(i);

    const frame = document.createElement('div');
    frame.className = 'tile-frame';
    frame.style.aspectRatio = `${t.width} / ${t.height}`;

    const img = document.createElement('img');
    img.src = t.src;
    img.alt = t.title;
    img.loading = 'lazy';
    frame.appendChild(img);

    const cap = document.createElement('div');
    cap.className = 'tile-caption';
    cap.innerHTML = `
      <span class="ttl">${t.title}</span>
      <span class="num">N° ${pad(i + 1)}</span>
    `;

    a.appendChild(frame);
    a.appendChild(cap);
    a.addEventListener('click', (e) => { e.preventDefault(); openLightbox(i); });
    gallery.appendChild(a);
  });

  /* Tab filtering */
  const tabs = document.querySelectorAll('.tab');
  const tabMeta = document.getElementById('tabMeta');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      const cat = tab.dataset.cat;
      let n = 0;
      document.querySelectorAll('.tile').forEach((tile) => {
        const match = cat === 'all' || tile.dataset.cat === cat;
        tile.classList.toggle('is-hidden', !match);
        if (match) n++;
      });
      if (tabMeta) tabMeta.textContent = `Showing ${n} ${n === 1 ? 'photo' : 'photos'}`;
    });
  });

  /* Lightbox */
  const lb = document.getElementById('lightbox');
  const lbFrame = document.getElementById('lbFrame');
  const lbCaption = document.getElementById('lbCaption');
  const lbPrev = document.getElementById('lbPrev');
  const lbNext = document.getElementById('lbNext');
  const lbClose = document.getElementById('lbClose');
  let currentIdx = 0;

  function visibleTiles() {
    return [...document.querySelectorAll('.tile:not(.is-hidden)')]
      .map((t) => parseInt(t.dataset.idx, 10));
  }

  function renderLb() {
    const t = TILES[currentIdx];
    lbFrame.innerHTML = '';
    const img = document.createElement('img');
    img.src = t.src;
    img.alt = t.title;
    img.style.aspectRatio = `${t.width} / ${t.height}`;
    lbFrame.appendChild(img);
    lbCaption.querySelector('.lb-plate').textContent = `Photo N° ${pad(currentIdx + 1)} — ${CAT_LABEL[t.cat]}`;
    lbCaption.querySelector('.lb-title').textContent = t.title;
    lbCaption.querySelector('.lb-meta').textContent = t.file;
  }

  function openLightbox(idx) {
    currentIdx = idx;
    renderLb();
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function step(d) {
    const list = visibleTiles();
    if (!list.length) return;
    const pos = list.indexOf(currentIdx);
    const nextPos = (pos + d + list.length) % list.length;
    currentIdx = list[nextPos];
    renderLb();
  }

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => step(-1));
  lbNext.addEventListener('click', () => step(+1));
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') step(-1);
    if (e.key === 'ArrowRight') step(+1);
  });
</script>
